# ============================================
# xxxaccounter — Environment
# Copy to .env and fill in values
# ============================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=traforama
POSTGRES_PASSWORD=traforama
POSTGRES_DB=traforama
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_PORT=6379

# ── ClickHouse ───────────────────────────────────────────────
CLICKHOUSE_DB=traforama
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# ── API (Go service) ────────────────────────────────────────
API_PORT=8080
# Cache TTLs (Go duration format)
CACHE_LIST_TTL=60s
CACHE_DETAIL_TTL=300s
# Event buffer for ClickHouse writes
EVENT_BUFFER_SIZE=1000
EVENT_FLUSH_INTERVAL=1s
# Rate limiting (requests per second)
RATE_LIMIT_RPS=100

# ── Parser Worker (Python) ──────────────────────────────────
# Polling interval for parse queue
PARSE_INTERVAL_SEC=30
# Disable account after N consecutive parse errors
MAX_PARSE_ERRORS=5
LOG_LEVEL=INFO

# ── S3 / Cloudflare R2 (media storage) ─────────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=xcj-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
# Public CDN URL for uploaded media (thumbnails, previews)
S3_PUBLIC_URL=

# ── Claude AI (categorization) ─────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Max concurrent categorization requests
CATEGORIZER_CONCURRENCY=5
# Batch size per pipeline run
CATEGORIZER_BATCH_SIZE=50

# ── Gemini (banner image editing) ─────────────────────────────
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-image

# ── Web (Next.js frontend) ──────────────────────────────────
WEB_PORT=3000
# Internal API URL (server-side, within Docker network)
# Set automatically in docker-compose; override for custom setups
# API_URL=http://api:8080
# Public API URL (client-side, browser access)
NEXT_PUBLIC_API_URL=http://localhost:8080
