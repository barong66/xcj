# ============================================
# xxxaccounter — Production Environment
# Copy to .env and fill in values
# ============================================

# ── PostgreSQL ───────────────────────────────────────────────
# Used by docker-compose for the PostgreSQL container
POSTGRES_USER=traforama
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=traforama

# ── ClickHouse ───────────────────────────────────────────────
CLICKHOUSE_DB=traforama
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── API (Go service) ────────────────────────────────────────
# Admin API token — change this!
ADMIN_TOKEN=CHANGE_ME_RANDOM_TOKEN

# Cache TTLs
CACHE_LIST_TTL=60s
CACHE_DETAIL_TTL=300s

# Event buffer for ClickHouse writes
EVENT_BUFFER_SIZE=1000
EVENT_FLUSH_INTERVAL=1s

# Rate limiting
RATE_LIMIT_RPS=100

# ── Media storage (AWS S3) ──────────────────────────────────
S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
S3_BUCKET=xcj-media
S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_REGION=eu-central-1
S3_PUBLIC_URL=https://xcj-media.s3.eu-central-1.amazonaws.com

# ── Claude AI (categorization) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CATEGORIZER_CONCURRENCY=5
CATEGORIZER_BATCH_SIZE=50

# ── Apify (Instagram scraping) ──────────────────────────────
APIFY_TOKEN=apify_api_XXXXXXXXXXXX
APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper
APIFY_INSTAGRAM_RESULTS_LIMIT=50

# ── Web (Next.js) ──────────────────────────────────────────
# Before domain: use http://HETZNER_IP:8080
# After domain:  use https://yourdomain.com
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP
NEXT_PUBLIC_SITE_NAME=xxxaccounter
NEXT_PUBLIC_SITE_URL=http://YOUR_SERVER_IP

# ── Parser Worker ───────────────────────────────────────────
PARSE_INTERVAL_SEC=30
MAX_PARSE_ERRORS=5
LOG_LEVEL=INFO
